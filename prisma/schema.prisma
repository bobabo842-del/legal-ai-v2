generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LegalArticle {
  id         String   @id @default(cuid())

  lawName    String

  articleNo  String

  content    String

  embedding  String

  createdAt  DateTime @default(now())
}